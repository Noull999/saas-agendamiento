{
  "name": "saas-agendamiento-backend",
  "version": "1.0.0",
  "description": "Backend API para SaaS de agendamiento multi-tenant",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "test": "jest --testPathPatterns='src/__tests__'",
    "test:watch": "jest --watch --testPathPatterns='src/__tests__'",
    "seed:demo": "node seed-demo.js"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/src/__tests__/**/*.test.js"
    ]
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "express-rate-limit": "^8.4.1",
    "googleapis": "^173.0.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "mercadopago": "^3.1.0",
    "nodemailer": "^8.0.7",
    "pdfkit": "^0.19.0",
    "pg": "^8.21.0",
    "stripe": "^22.1.0",
    "twilio": "^6.0.2"
  },
  "devDependencies": {
    "jest": "^30.3.0",
    "nodemon": "^3.1.0"
  }
}
