# .env.example - TEMPLATE SOLAMENTE, NO GUARDAR SECRETOS
# Copia este archivo a .env en tu entorno local/producción
# Reemplaza los valores con tus secretos reales (ver SECRETS.md para generación)

# === SECRETS (CAMBIAR EN CADA ENTORNO) ===
JWT_SECRET=CHANGE_ME_AT_LEAST_32_CHARS_LONG_RANDOM_STRING
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# === DATABASE (PostgreSQL) ===
DATABASE_URL=postgresql://user:password@localhost:5432/saas_prod

# === OPCIONAL: Servicios Externos (PRODUCTION ONLY) ===
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=price_xxx
STRIPE_PRICE_BUSINESS=price_xxx
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SENTRY_DSN=

# === CONFIG (PUEDE ESTAR EN REPO) ===
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:5173
