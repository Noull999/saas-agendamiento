PORT=3001
JWT_SECRET=cambia_esto_por_minimo_32_caracteres_aleatorios
DB_PATH=./data/saas.db
NODE_ENV=development

# En producción, poner la URL del frontend de Vercel:
# FRONTEND_URL=https://tu-app.vercel.app

# Encriptación de datos sensibles (requerido para datos de salud)
# Genera con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=cambia_esto_por_exactamente_64_hex_chars_minimo!!

# ── Email (SMTP) — confirmaciones de reserva + recuperación de contraseña ───
# Si no se configura, el sistema funciona solo con WhatsApp (silencioso).
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=tu@gmail.com
# SMTP_PASS=tu_app_password_gmail   (contraseña de aplicación, no la personal)
# SMTP_FROM="Tu Clínica <noreply@tu-dominio.com>"   (opcional, usa SMTP_USER si se omite)

# ── WhatsApp via Twilio (opción recomendada para producción) ──────────────────
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=tu_auth_token
# TWILIO_WHATSAPP_FROM=+14155238886   # número Twilio Sandbox o aprobado

# ── WhatsApp via bot propio (alternativa) ────────────────────────────────────
# WHATSAPP_BOT_URL=http://localhost:3002
# WHATSAPP_BOT_SECRET=tu-secret-aqui

# ── Stripe (pagos de planes Pro / Clínica) ───────────────────────────────────
# STRIPE_SECRET_KEY=sk_live_xxx   (usa sk_test_xxx para pruebas)
# STRIPE_WEBHOOK_SECRET=whsec_xxx  (obtenido en el dashboard de Stripe)
# STRIPE_PRICE_PRO=price_xxx       (ID del precio mensual del plan Pro)
# STRIPE_PRICE_CLINICA=price_xxx   (ID del precio mensual del plan Clínica)

# ── Mercado Pago (cobro previo al reservar) ─────────────────────────────────
# Opcional: si se define aquí aplica a todos los negocios; si no, cada negocio
# configura su propio token en Configuración → Mercado Pago.
# Usa TEST-xxx para sandbox; APP_USR-xxx para producción.
# MERCADO_PAGO_ACCESS_TOKEN=APP_USR-xxxxxxxxxxxx
# MERCADO_PAGO_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx  (para verificar firma de webhooks)
# URL pública del backend, necesaria para el notification_url del webhook de MP:
# BACKEND_URL=https://tu-api.railway.app

# ─── Monitoring (UptimeRobot) ─────────────────────────────────────────────────
# Set up free monitors at https://uptimerobot.com for:
#   SaaS API:      https://saas-agendamiento-production.up.railway.app/health
#   Frontend:      https://workly.cl
#   WhatsApp Bot:  (your bot Railway URL)/health
# UPTIME_ROBOT_API_KEY=  (optional, only needed for programmatic alerts)
